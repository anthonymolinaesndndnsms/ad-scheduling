# ── Kids Next Door — environment variables ──────────────────────────

# Supabase Postgres — transaction pooler (used by the running app; port 6543)
# Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@[pooler-host].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Postgres — session pooler (used only for `prisma db push` / migrations; port 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@[pooler-host].pooler.supabase.com:5432/postgres"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — username/password login works without it)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

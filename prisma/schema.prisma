generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum JobStatus {
  PENDING
  COMPLETED
}

enum CashStatus {
  OUTSTANDING
  COLLECTED
}

enum PayoutStatus {
  UNPAID
  PAID
}

enum LeadStatus {
  NOT_HOME
  INTERESTED
  FOLLOW_UP
  BOOKED
  NOT_INTERESTED
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  email        String?  @unique
  passwordHash String?
  image        String?
  phone        String?
  role         Role     @default(EMPLOYEE)
  active       Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs          Job[]          @relation("EmployeeJobs")
  payouts       Payout[]
  notifications Notification[]
  availability  Availability[]
  services      ServiceType[]  @relation("EmployeeServices")

  @@map("users")
}

model Availability {
  id            String  @id @default(cuid())
  userId        String
  dayOfWeek     Int // 0 = Sunday ... 6 = Saturday
  startTime     String // "HH:mm" 24h
  endTime       String // "HH:mm" 24h
  maxJobsPerDay Int?
  notes         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("availability")
}

model ServiceType {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  color               String   @default("#3b82f6")
  defaultPriceCents   Int?
  defaultDurationMins Int?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  jobs      Job[]
  employees User[] @relation("EmployeeServices")
  leads     Lead[] @relation("LeadInterests")

  @@map("service_types")
}

model Customer {
  id           String   @id @default(cuid())
  name         String
  phone        String?
  address      String
  neighborhood String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs Job[]

  @@index([name])
  @@map("customers")
}

model Job {
  id                   String       @id @default(cuid())
  title                String
  serviceTypeId        String
  employeeId           String?
  customerId           String?
  address              String
  neighborhood         String
  startTime            DateTime
  durationMins         Int          @default(60)
  priceCents           Int
  tipCents             Int          @default(0)
  employeeSplitPercent Int          @default(80) // snapshot of the split at creation time
  status               JobStatus    @default(PENDING)
  cashStatus           CashStatus   @default(OUTSTANDING)
  payoutStatus         PayoutStatus @default(UNPAID)
  customerComments     String?
  specifications       String?
  completionNotes      String?
  adminNotes           String?
  completedAt          DateTime?
  payoutId             String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])
  employee    User?       @relation("EmployeeJobs", fields: [employeeId], references: [id], onDelete: SetNull)
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  payout      Payout?     @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([employeeId, startTime])
  @@index([startTime])
  @@index([status])
  @@map("jobs")
}

model Payout {
  id          String   @id @default(cuid())
  employeeId  String
  amountCents Int // sum of employee job shares included in this payout (excluding tips)
  tipCents    Int      @default(0)
  note        String?
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  employee User  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  jobs     Job[]

  @@index([employeeId, paidAt])
  @@map("payouts")
}

model Lead {
  id                  String     @id @default(cuid())
  address             String
  neighborhood        String
  name                String?
  phone               String?
  status              LeadStatus @default(NOT_HOME)
  notes               String?
  followUpDate        DateTime?
  convertedCustomerId String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  interestedServices ServiceType[] @relation("LeadInterests")

  @@index([status])
  @@map("leads")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model Settings {
  id                     String   @id @default("singleton")
  businessName           String   @default("Kids Next Door")
  logoUrl                String?
  employeeSplitPercent   Int      @default(80)
  defaultJobDurationMins Int      @default(60)
  defaultBufferMins      Int      @default(30)
  neighborhoods          String[] @default([])
  currency               String   @default("USD")
  timezone               String   @default("America/New_York")
  updatedAt              DateTime @updatedAt

  @@map("settings")
}
